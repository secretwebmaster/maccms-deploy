# MacCMS Deploy Environment Config Example
# Copy this file to .env and edit values before running install.sh

DOMAIN=example.com
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=example_db
DB_USER=example_db
DB_PASS=yourpassword
# Optional: SITE_TYPE=movie|adult
SITE_TYPE=movie
# Optional: GIT_REPO=https://github.com/secretwebmaster/maccms.git
GIT_REPO=https://github.com/secretwebmaster/maccms.git
